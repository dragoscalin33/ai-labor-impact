# Copy this file to `.streamlit/secrets.toml` (gitignored) for local use,
# or paste these keys into the Streamlit Community Cloud "Secrets" panel.
#
# The dashboard works WITHOUT any of these — the bundled
# `data/insights_cache.json` provides rich narrative for free.
# These keys only matter if you want LIVE LLM calls in the Insights tab.

# Groq (free tier — get a key at https://console.groq.com)
GROQ_API_KEY = "gsk_your_key_here"

# Anthropic Claude (paid — https://console.anthropic.com)
ANTHROPIC_API_KEY = "sk-ant-your_key_here"
