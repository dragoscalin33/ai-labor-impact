# Copy this file to .env and fill in your API keys
# .env is in .gitignore — never commit actual keys

# Groq API (free tier at console.groq.com — no credit card needed)
GROQ_API_KEY=gsk_your_key_here

# Anthropic Claude API (optional)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# FRED (Federal Reserve) economic data API (free at fred.stlouisfed.org)
FRED_API_KEY=your_fred_key_here

# World Bank API — NO KEY NEEDED (public API)
# Metaculus API — NO KEY NEEDED for public questions
